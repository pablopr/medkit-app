# Copy this file to `backend/.env.local` and fill in the values.
# The backend reads these at startup — restart the server after editing.
#
# WARNING: .env.local is gitignored. Never commit API keys.

# OpenRouter key for the vetkit-attending grader, text patient persona,
# and voice worker LLM. Server-side only — never set this in a VITE_*
# variable and never return it to the browser.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.2
OPENROUTER_GRADER_MODEL=openai/gpt-5.2
OPENROUTER_TRIAGE_MODEL=openai/gpt-5.2
OPENROUTER_PATIENT_MODEL=openai/gpt-5.2
OPENROUTER_VOICE_MODEL=openai/gpt-5.2
OPENROUTER_VOICE_ACTION_MODEL=openai/gpt-5.2
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=Vetkit

# LiveKit Cloud — https://cloud.livekit.io. Used by the FastAPI server
# to mint room JWTs and by voice_agent.py to register as a worker.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Deepgram — https://deepgram.com. Streaming STT inside the voice worker.
DEEPGRAM_API_KEY=

# Cartesia — https://cartesia.ai. Streaming TTS inside the voice worker.
CARTESIA_API_KEY=
